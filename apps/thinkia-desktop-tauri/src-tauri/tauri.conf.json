{
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../..",
    "beforeBuildCommand": "node ./scripts/write-shell.mjs",
    "devPath": "http://localhost:5173/portal/",
    "distDir": "../dist-web",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Thinkia",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "bundle": {
      "active": true,
      "identifier": "com.thinkia.desktop",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "shortDescription": "Thinkia — Call Center",
      "longDescription": "Cliente escritorio: abre el portal web Thinkia (Supabase + Twilio) en una ventana nativa.",
      "category": "Business",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "width": 1400,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "title": "Thinkia"
      }
    ]
  }
}
