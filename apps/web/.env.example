# --- Supabase (AICONCTATC-84) — URL + anon en cliente; service role SOLO servidor (Vercel / Cloud Run) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Opcional (solo servidor): mismos valores que arriba si en Vercel las NEXT_PUBLIC_ fallan en rutas /api:
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Nunca NEXT_PUBLIC_ para la clave privilegiada:
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Portal de login (Vite) + handoff de sesión al dominio Next (softphone) ---
# Despliegue único (recomendado): deja NEXT_PUBLIC_VITE_LOGIN_URL vacío; el portal se sirve en /portal/ y el
# handoff CORS permite automáticamente el mismo Origin que Next. Para segundo proyecto Vite (legacy):
# NEXT_PUBLIC_VITE_LOGIN_URL=https://tu-portal.vercel.app
# AUTH_HANDOFF_ALLOWED_ORIGIN=https://tu-portal.vercel.app
AUTH_HANDOFF_ALLOWED_ORIGIN=http://localhost:3000

# --- C3 — token Twilio para apps móviles (POST /api/token/mobile) ---
# Opcional: CORS si el cliente envía Origin (p. ej. Expo web). Si vacío, se reutiliza AUTH_HANDOFF_ALLOWED_ORIGIN.
# TOKEN_MOBILE_ALLOWED_ORIGINS=https://tu-expo-web.dev

# --- Demo: simular ring en el portal (POST /api/dev/simulate-client-ring, con sesión). TWILIO_CALLER_ID debe tener Voice. ---
# ALLOW_CLIENT_RING_SIMULATION=true

# URL pública del despliegue Next (callbacks Twilio status → /api/twilio/voice-status). En Vercel suele bastar VERCEL_URL;
# si la validación de firma falla, fija aquí la misma base que ves en el navegador (sin barra final).
# NEXT_PUBLIC_APP_URL=https://tu-proyecto.vercel.app

# --- Twilio (AICONCTATC-77) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CALLER_ID=+34123456789
# Opcional: validación X-Twilio-Signature en POST /api/twilio/voice-status (Auth Token de la consola Twilio, no la API Key).
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
